# 텔레그램 봇 토큰 (@BotFather에서 발급)
TELEGRAM_BOT_TOKEN=여기에_봇_토큰_입력

# 텔레그램 채널 ID (예: @puel_insight)
TELEGRAM_CHANNEL_ID=@여기에_채널_아이디_입력

# 텔레그램 API 인증 (https://my.telegram.org 에서 발급)
TELEGRAM_API_ID=여기에_API_ID_숫자_입력
TELEGRAM_API_HASH=여기에_API_HASH_입력

# Anthropic API 키 (https://console.anthropic.com 에서 발급)
ANTHROPIC_API_KEY=sk-ant-여기에_API_키_입력
